{
  "name": "issuepilot-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "node --import tsx --test tests/*.test.ts",
    "db:migrate": "tsx src/scripts/migrate.ts"
  },
  "dependencies": {
    "cors": "2.8.5",
    "dotenv": "17.2.3",
    "express": "5.1.0",
    "pg": "8.16.3",
    "redis": "^6.0.0",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.5",
    "@types/node": "22.18.12",
    "@types/pg": "8.15.5",
    "tsx": "4.20.6",
    "typescript": "5.9.3"
  }
}
